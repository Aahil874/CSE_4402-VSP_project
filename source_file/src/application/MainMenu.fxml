<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="592.0" prefWidth="766.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="application.MainMenuController">
   <children>
      <VBox layoutX="41.0" layoutY="28.0" prefHeight="493.0" prefWidth="639.0" spacing="20.0" styleClass="menu-container" stylesheets="@application.css" AnchorPane.leftAnchor="41.0" AnchorPane.rightAnchor="86.0">
         <children>
            <Label prefHeight="73.0" prefWidth="584.0" styleClass="menu-title" text="BASEBALL MENU SYSTEM">
               <font>
                  <Font size="30.0" />
               </font>
            </Label>
            <Button fx:id="playMatchBtn" mnemonicParsing="false" onAction="#onPlayMatch" styleClass="menu-button" text="Play New Match">
               <VBox.margin>
                  <Insets left="50.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="trainingBtn" mnemonicParsing="false" onAction="#onTraining" styleClass="menu-button" text="Training">
               <VBox.margin>
                  <Insets left="50.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="seePlayersBtn" mnemonicParsing="false" onAction="#onSeePlayers" styleClass="menu-button" text="Team Selection">
               <VBox.margin>
                  <Insets left="50.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="transfersBtn" mnemonicParsing="false" onAction="#onTransfers" styleClass="menu-button" text="Player Transfers">
               <VBox.margin>
                  <Insets left="50.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="selectStadiumBtn" mnemonicParsing="false" onAction="#onSelectStadium" styleClass="menu-button" text="Stadium Selection">
               <VBox.margin>
                  <Insets left="50.0" />
               </VBox.margin>
            </Button>
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding></VBox>
   </children>
</AnchorPane>
